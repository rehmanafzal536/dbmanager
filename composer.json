{
    "name": "rehmanafzal/dbmanager",
    "description": "A powerful database manager for Laravel — supports SQLite & MySQL with a clean UI",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "database", "manager", "sqlite", "mysql", "admin", "dbmanager"],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/routing": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/database": "^9.0|^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Devtoolkit\\DbManager\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Devtoolkit\\DbManager\\DbManagerServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
